<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Food Gorilla</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  </head>
  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container">
        <a class="navbar-brand" href="/">Food Gorilla</a>
        <div class="navbar-nav ms-auto">
          <a class="nav-link" href="/menu">Menu</a>
          <a class="nav-link" href="/register">Register</a>
          <a class="nav-link" href="/login">Login</a>
          <a class="nav-link" href="/dashboard">Dashboard</a>
          <a class="nav-link" href="/checkout">Checkout</a>
          <a class="nav-link" href="/logout">Logout</a>
        </div>
      </div>
    </nav>
    <main class="container py-4">
      <div class="p-5 mb-4 bg-light rounded-3">
        <div class="container-fluid py-5">
          <h1 class="display-5 fw-bold">Food Gorilla</h1>
          <p class="col-md-8 fs-4">Explore smart menu filtering, secure checkout, and daily macro tracking in one place.</p>
          <a class="btn btn-primary btn-lg" href="/menu">View menu</a>
        </div>
      </div>
      <div class="card">
        <div class="card-body">
          <h2 class="h5">Backend status</h2>
          <p class="mb-1"><strong>Status:</strong> <%= status %></p>
          <p class="mb-0"><strong>Database:</strong> <%= databaseConnectivity %></p>
        </div>
      </div>
    </main>
  </body>
</html>
