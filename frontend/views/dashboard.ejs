<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Food Gorilla | Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
    <style>
      .trend-bar {
        height: 24px;
        border-radius: 0.5rem;
        position: relative;
        overflow: hidden;
      }
      .trend-bar-fill {
        height: 100%;
        background-color: #0d6efd;
      }
      .trend-bar-target {
        position: absolute;
        top: 0;
        bottom: 0;
        width: 2px;
        background: rgba(220, 53, 69, 0.9);
        right: 10%;
      }
      .progress-label {
        min-width: 90px;
      }
      .dashboard-alerts .alert {
        margin-bottom: 0.75rem;
      }
      .dashboard-alerts .alert i {
        font-size: 1.2rem;
      }
    </style>
  </head>
  <body>
    <%- include('partials/navbar', { active: 'dashboard', isAuthenticated }) %>
    <main class="container py-4">
      <h1 class="h3 mb-4">Fitness Dashboard</h1>

      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <% if (dashboard) { %>
        <div class="row gy-4">
          <div class="col-12 col-lg-6">
            <div class="card shadow-sm">
              <div class="card-body">
                <h2 class="h5 mb-3">Today&apos;s Macro Progress</h2>
                <% dashboard.progress.forEach((item) => { %>
                  <div class="d-flex align-items-center mb-2">
                    <span class="progress-label"><strong><%= item.label %></strong></span>
                    <span class="ms-auto"><%= item.consumed %> / <%= item.target %></span>
                  </div>
                  <div class="progress mb-3" style="height: 1.5rem;">
                    <% const percent = item.percent; %>
                    <% if (item.color === 'green') { %>
                      <div class="progress-bar bg-success" role="progressbar" data-percent="<%= percent %>" aria-valuenow="<%= percent %>" aria-valuemin="0" aria-valuemax="100">
                        <%= percent %>%
                      </div>
                    <% } else if (item.color === 'orange') { %>
                      <div class="progress-bar bg-warning" role="progressbar" data-percent="<%= percent %>" aria-valuenow="<%= percent %>" aria-valuemin="0" aria-valuemax="100">
                        <%= percent %>%
                      </div>
                    <% } else { %>
                      <div class="progress-bar bg-danger" role="progressbar" data-percent="<%= percent %>" aria-valuenow="<%= percent %>" aria-valuemin="0" aria-valuemax="100">
                        <%= percent %>%
                      </div>
                    <% } %>
                  </div>
                <% }); %>

                <div class="mt-3 dashboard-alerts">
                  <h3 class="h6">Alerts</h3>
                  <% const exceededAlerts = dashboard.progress.filter(item => item.consumed > item.target); %>
                  <% const achievedAlerts = dashboard.progress.filter(item => item.consumed === item.target); %>
                  <% const warningAlerts = dashboard.progress.filter(item => item.consumed < item.target && item.percent >= 75); %>

                  <% if (exceededAlerts.length || warningAlerts.length || achievedAlerts.length) { %>
                    <% exceededAlerts.forEach((item) => { %>
                      <div class="alert alert-danger d-flex align-items-center" role="alert">
                        <i class="bi bi-x-circle-fill me-3"></i>
                        <div>
                          <strong><%= item.label %> exceeded</strong>
                          <div>Goal exceeded by <%= item.consumed - item.target %> <%= item.label === 'Calories' ? 'kcal' : 'g' %>.</div>
                        </div>
                      </div>
                    <% }); %>
                    <% warningAlerts.forEach((item) => { %>
                      <div class="alert alert-warning d-flex align-items-center" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-3"></i>
                        <div>
                          <strong><%= item.label %> is approaching target</strong>
                          <div><%= item.label %> is at <%= item.percent %>% of your daily goal.</div>
                        </div>
                      </div>
                    <% }); %>
                    <% achievedAlerts.forEach((item) => { %>
                      <div class="alert alert-success d-flex align-items-center" role="alert">
                        <i class="bi bi-check-circle-fill me-3"></i>
                        <div>
                          <strong><%= item.label %> goal achieved</strong>
                          <div><%= item.label %> is exactly on target at <%= item.target %> <%= item.label === 'Calories' ? 'kcal' : 'g' %>.</div>
                        </div>
                      </div>
                    <% }); %>
                  <% } else { %>
                    <div class="alert alert-success d-flex align-items-center" role="alert">
                      <i class="bi bi-check-circle-fill me-3"></i>
                      <div>
                        <strong>Great job!</strong>
                        <div>All nutrition goals are on track today.</div>
                      </div>
                    </div>
                  <% } %>
                </div>
              </div>
            </div>
          </div>

          <div class="col-12 col-lg-6">
            <div class="card shadow-sm">
              <div class="card-body">
                <h2 class="h5 mb-3">Weekly Nutrition Summary</h2>
                <div class="mb-3">
                  <p class="mb-1"><strong>Average Calories/Day:</strong> <%= dashboard.summary.average_calories_per_day %></p>
                  <p class="mb-1"><strong>Days on Track:</strong> <%= dashboard.summary.days_on_track %> / 7</p>
                  <p class="mb-0"><strong>Times Exceeded:</strong> <%= dashboard.summary.times_exceeded %></p>
                </div>
                <div class="mb-3">
                  <div class="d-flex justify-content-between fw-semibold mb-2">
                    <span>Daily Calories</span>
                    <span>Target <%= dashboard.targets.daily_calorie_target %></span>
                  </div>
                  <% dashboard.weekly.forEach((entry) => { %>
                    <div class="mb-3">
                      <div class="d-flex justify-content-between mb-1">
                        <span><%= new Date(entry.date).toLocaleDateString() %></span>
                        <span><%= entry.calories %></span>
                      </div>
                      <div class="trend-bar bg-light">
                        <% if (entry.exceeded) { %>
                          <div class="trend-bar-fill bg-danger" data-width="<%= Math.min(100, entry.percent_of_target) %>"></div>
                        <% } else { %>
                          <div class="trend-bar-fill bg-primary" data-width="<%= Math.min(100, entry.percent_of_target) %>"></div>
                        <% } %>
                        <div class="trend-bar-target"></div>
                      </div>
                    </div>
                  <% }); %>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% } %>
    </main>
    <script>
      document.querySelectorAll('.progress-bar[data-percent]').forEach((bar) => {
        const percent = Number(bar.dataset.percent || 0);
        bar.style.width = `${Math.min(100, Math.max(0, percent))}%`;
      });

      document.querySelectorAll('.trend-bar-fill[data-width]').forEach((bar) => {
        const percent = Number(bar.dataset.width || 0);
        bar.style.width = `${Math.min(100, Math.max(0, percent))}%`;
      });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
