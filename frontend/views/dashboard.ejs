<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Food Gorilla | Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
      .trend-bar {
        height: 24px;
        border-radius: 0.5rem;
        position: relative;
        overflow: hidden;
      }
      .trend-bar-fill {
        height: 100%;
        background-color: #0d6efd;
      }
      .trend-bar-target {
        position: absolute;
        top: 0;
        bottom: 0;
        width: 2px;
        background: rgba(220, 53, 69, 0.9);
        right: 10%;
      }
      .progress-label {
        min-width: 90px;
      }
    </style>
  </head>
  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container">
        <a class="navbar-brand" href="/">Food Gorilla</a>
        <div class="navbar-nav ms-auto">
          <a class="nav-link <%= active === 'menu' ? 'active' : '' %>" href="/menu">Menu</a>
          <a class="nav-link <%= active === 'dashboard' ? 'active' : '' %>" href="/dashboard">Dashboard</a>
          <a class="nav-link <%= active === 'register' ? 'active' : '' %>" href="/register">Register</a>
          <a class="nav-link <%= active === 'login' ? 'active' : '' %>" href="/login">Login</a>
          <a class="nav-link <%= active === 'checkout' ? 'active' : '' %>" href="/checkout">Checkout</a>
          <a class="nav-link" href="/logout">Logout</a>
        </div>
      </div>
    </nav>
    <main class="container py-4">
      <h1 class="h3 mb-4">Fitness Dashboard</h1>

      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <% if (dashboard) { %>
        <div class="row gy-4">
          <div class="col-12 col-lg-6">
            <div class="card shadow-sm">
              <div class="card-body">
                <h2 class="h5 mb-3">Today&apos;s Macro Progress</h2>
                <% dashboard.progress.forEach((item) => { %>
                  <div class="d-flex align-items-center mb-2">
                    <span class="progress-label"><strong><%= item.label %></strong></span>
                    <span class="ms-auto"><%= item.consumed %> / <%= item.target %></span>
                  </div>
                  <div class="progress mb-3" style="height: 1.5rem;">
                    <div class="progress-bar bg-<%= item.color === 'green' ? 'success' : item.color === 'orange' ? 'warning' : 'danger' %>" role="progressbar" style="width: <%= item.percent %>%" aria-valuenow="<%= item.percent %>" aria-valuemin="0" aria-valuemax="100">
                      <%= item.percent %>%
                    </div>
                  </div>
                <% }); %>

                <div class="mt-3">
                  <h3 class="h6">Alerts</h3>
                  <% const redAlerts = dashboard.progress.filter(item => item.color === 'red'); %>
                  <% if (redAlerts.length) { %>
                    <div class="alert alert-danger">Exceeded: <%= redAlerts.map(item => item.label).join(', ') %></div>
                  <% } else { %>
                    <div class="alert alert-info">No macros exceeded yet.</div>
                  <% } %>
                </div>
              </div>
            </div>
          </div>

          <div class="col-12 col-lg-6">
            <div class="card shadow-sm">
              <div class="card-body">
                <h2 class="h5 mb-3">Weekly Nutrition Summary</h2>
                <div class="mb-3">
                  <p class="mb-1"><strong>Average Calories/Day:</strong> <%= dashboard.summary.average_calories_per_day %></p>
                  <p class="mb-1"><strong>Days on Track:</strong> <%= dashboard.summary.days_on_track %> / 7</p>
                  <p class="mb-0"><strong>Times Exceeded:</strong> <%= dashboard.summary.times_exceeded %></p>
                </div>
                <div class="mb-3">
                  <div class="d-flex justify-content-between fw-semibold mb-2">
                    <span>Daily Calories</span>
                    <span>Target <%= dashboard.targets.daily_calorie_target %></span>
                  </div>
                  <% dashboard.weekly.forEach((entry) => { %>
                    <div class="mb-3">
                      <div class="d-flex justify-content-between mb-1">
                        <span><%= new Date(entry.date).toLocaleDateString() %></span>
                        <span><%= entry.calories %></span>
                      </div>
                      <div class="trend-bar bg-light">
                        <div class="trend-bar-fill" style="width: <%= Math.min(100, entry.percent_of_target) %>% ; background-color: <%= entry.exceeded ? '#dc3545' : '#0d6efd' %>;"></div>
                        <div class="trend-bar-target" style="left: calc(<%= (dashboard.targets.daily_calorie_target > 0 ? Math.min(100, (dashboard.targets.daily_calorie_target / dashboard.targets.daily_calorie_target) * 100) : 100) %>% - 1px);"></div>
                      </div>
                    </div>
                  <% }); %>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% } %>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
