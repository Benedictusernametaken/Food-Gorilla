<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Food Gorilla | Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  </head>
  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container">
        <a class="navbar-brand" href="/">Food Gorilla</a>
        <div class="navbar-nav ms-auto">
          <a class="nav-link" href="/menu">Menu</a>
          <a class="nav-link" href="/register">Register</a>
          <a class="nav-link" href="/login">Login</a>
          <a class="nav-link active" href="/dashboard">Dashboard</a>
          <a class="nav-link" href="/checkout">Checkout</a>
          <a class="nav-link" href="/logout">Logout</a>
        </div>
      </div>
    </nav>
    <main class="container py-4">
      <h1 class="h3 mb-4">Today’s macro summary</h1>
      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>
      <div class="row g-3">
        <div class="col-md-3">
          <div class="card shadow-sm">
            <div class="card-body">
              <h2 class="h6">Calories</h2>
              <p class="display-6 mb-0"><%= summary ? summary.total_calories_consumed : 0 %></p>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card shadow-sm">
            <div class="card-body">
              <h2 class="h6">Protein</h2>
              <p class="display-6 mb-0"><%= summary ? summary.total_protein_consumed : 0 %>g</p>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card shadow-sm">
            <div class="card-body">
              <h2 class="h6">Carbs</h2>
              <p class="display-6 mb-0"><%= summary ? summary.total_carbs_consumed : 0 %>g</p>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card shadow-sm">
            <div class="card-body">
              <h2 class="h6">Fats</h2>
              <p class="display-6 mb-0"><%= summary ? summary.total_fats_consumed : 0 %>g</p>
            </div>
          </div>
        </div>
      </div>
    </main>
  </body>
</html>
