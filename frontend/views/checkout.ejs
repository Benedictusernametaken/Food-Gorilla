<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Food Gorilla | Checkout</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  </head>
  <body>
    <%- include('partials/navbar', { active: 'checkout', isAuthenticated }) %>
    <main class="container py-4">
      <h1 class="h3 mb-4">Checkout</h1>
      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>
      <% if (success) { %>
        <div class="alert alert-success"><%= success %></div>
      <% } %>
      <% if (alerts && alerts.length) { %>
        <div class="alert alert-warning">
          <strong>Macro alert:</strong>
          <%= alerts.map((alert) => alert.macro).join(', ') %> changed tiers.
        </div>
      <% } %>
      <div class="card shadow-sm">
        <div class="card-body">
          <form method="post" action="/checkout">
            <div class="mb-3">
              <label class="form-label">Choose meal</label>
              <select class="form-select" name="meal_id">
                <% meals.forEach((meal) => { %>
                  <option value="<%= meal.meal_id %>"><%= meal.name %> — <%= meal.vendor_name || 'Unknown' %></option>
                <% }) %>
              </select>
            </div>
            <div class="mb-3">
              <label class="form-label">Quantity</label>
              <input class="form-control" type="number" name="quantity" min="1" value="1">
            </div>
            <button class="btn btn-primary">Place order</button>
          </form>
        </div>
      </div>
    </main>
  </body>
</html>
