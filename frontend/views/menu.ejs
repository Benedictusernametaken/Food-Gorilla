<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Food Gorilla | Menu</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  </head>
  <body>
    <%- include('partials/navbar', { active: 'menu', isAuthenticated }) %>
    <main class="container py-4">
      <h1 class="h3 mb-4">Smart Metric-Filtered Menu</h1>
      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>
      <div class="row g-4">
        <div class="col-lg-3">
          <div class="card shadow-sm">
            <div class="card-body">
              <h2 class="h5">Filter meals</h2>
              <label class="form-label">Calories: <span id="caloriesValue">1000</span></label>
              <input type="range" class="form-range" id="calories" min="0" max="1000" value="1000">
              <label class="form-label">Protein: <span id="proteinValue">100</span></label>
              <input type="range" class="form-range" id="protein" min="0" max="100" value="100">
              <label class="form-label">Carbs: <span id="carbsValue">200</span></label>
              <input type="range" class="form-range" id="carbs" min="0" max="200" value="200">
              <label class="form-label">Fats: <span id="fatsValue">100</span></label>
              <input type="range" class="form-range" id="fats" min="0" max="100" value="100">
            </div>
          </div>
        </div>
        <div class="col-lg-9">
          <div id="mealGrid" class="row g-3">
            <% meals.forEach((meal) => { %>
              <div class="col-md-6 meal-card" data-calories="<%= meal.base_calories %>" data-protein="<%= meal.base_protein %>" data-carbs="<%= meal.base_carbs %>" data-fats="<%= meal.base_fats %>">
                <div class="card h-100 shadow-sm">
                  <div class="card-body">
                    <h3 class="h5"><%= meal.name %></h3>
                    <p class="text-muted mb-2"><%= meal.vendor_name || 'Unknown restaurant' %></p>
                    <p class="small"><%= meal.description || '' %></p>
                    <ul class="list-unstyled small mb-0">
                      <li>Calories: <%= meal.base_calories %></li>
                      <li>Protein: <%= meal.base_protein %>g</li>
                      <li>Carbs: <%= meal.base_carbs %>g</li>
                      <li>Fats: <%= meal.base_fats %>g</li>
                    </ul>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      </div>
    </main>
    <script>
      const sliders = {
        calories: document.getElementById('calories'),
        protein: document.getElementById('protein'),
        carbs: document.getElementById('carbs'),
        fats: document.getElementById('fats')
      };
      const values = {
        calories: document.getElementById('caloriesValue'),
        protein: document.getElementById('proteinValue'),
        carbs: document.getElementById('carbsValue'),
        fats: document.getElementById('fatsValue')
      };

      function updateLabels() {
        values.calories.textContent = sliders.calories.value;
        values.protein.textContent = sliders.protein.value;
        values.carbs.textContent = sliders.carbs.value;
        values.fats.textContent = sliders.fats.value;
      }

      function filterMeals() {
        const maxCalories = Number(sliders.calories.value);
        const maxProtein = Number(sliders.protein.value);
        const maxCarbs = Number(sliders.carbs.value);
        const maxFats = Number(sliders.fats.value);

        document.querySelectorAll('.meal-card').forEach((card) => {
          const calories = Number(card.dataset.calories);
          const protein = Number(card.dataset.protein);
          const carbs = Number(card.dataset.carbs);
          const fats = Number(card.dataset.fats);
          const matches = calories <= maxCalories && protein <= maxProtein && carbs <= maxCarbs && fats <= maxFats;
          card.style.display = matches ? '' : 'none';
        });
      }

      Object.values(sliders).forEach((slider) => {
        slider.addEventListener('input', () => {
          updateLabels();
          filterMeals();
        });
      });

      updateLabels();
      filterMeals();
    </script>
  </body>
</html>
